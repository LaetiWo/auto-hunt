# --- APPLICATION CONFIGURATION ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEV_EMAIL_OVERRIDE=your_test_email@example.com

# --- APPWRITE PUBLIC CONFIGURATION (CLIENT-SIDE) ---
# These variables are exposed to the browser
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id
NEXT_PUBLIC_APPWRITE_DATABASE_ID=your_database_id

# Public Collection IDs
NEXT_PUBLIC_APPWRITE_COLLECTION_SHOP_ID=shop
NEXT_PUBLIC_APPWRITE_COLLECTION_CAR_LISTING_ID=car-listing
NEXT_PUBLIC_APPWRITE_BUCKET_IMAGES_ID=your_bucket_id

# --- APPWRITE PRIVATE CONFIGURATION (SERVER-SIDE) ---
# These variables are only accessible on the server
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id
APPWRITE_DATABASE_ID=your_database_id
APPWRITE_API_KEY=your_appwrite_api_key
NEXT_APPWRITE_KEY=your_appwrite_api_key

# Private Collection IDs
APPWRITE_COLLECTION_SHOP_ID=shop
APPWRITE_COLLECTION_CAR_LISTING_ID=car-listing
APPWRITE_COLLECTION_RENTALS_ID=rentals
APPWRITE_COLLECTION_NOTIFICATIONS_ID=notifications
APPWRITE_COLLECTION_REQUESTS_ID=vehicle_requests
APPWRITE_COLLECTION_USER_PROFILES_ID=user_profiles
APPWRITE_BUCKET_IMAGES_ID=your_bucket_id

# --- RESEND CONFIGURATION (EMAIL SERVICE) ---
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL="Auto Hunt <onboarding@resend.dev>"
